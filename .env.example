# Base operativa inicial de HNF Servicios Integrales
# Incluye solo variables necesarias para la base actual.

# Backend
BACKEND_PORT=4000
DB_PROVIDER=mongodb
DB_URI=mongodb://localhost:27017/hnf-servicios
DB_NAME=hnf-servicios
DB_FALLBACK_MODE=memory

# Frontend runtime
# Si se sirve el frontend como archivos estáticos, este valor puede inyectarse en frontend/env.js
API_BASE_URL=http://localhost:4000
