# Base operativa inicial de HNF Servicios Integrales
# Incluye solo variables necesarias para la base actual.

# Backend
BACKEND_PORT=4000
DB_PROVIDER=mongodb
DB_URI=mongodb://localhost:27017/hnf-servicios
DB_NAME=hnf-servicios
DB_FALLBACK_MODE=memory

# CORS (Render / API pública): orígenes exactos del frontend separados por coma.
# Incluir URL completa con esquema. Ejemplo Vercel:
# HNF_CORS_ORIGINS=https://hnf-xxx.vercel.app,https://tu-dominio.cl

# Frontend runtime (solo si sirvés estáticos sin VITE_API_BASE_URL)
# API_BASE_URL=http://localhost:4000
