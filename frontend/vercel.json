{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/env.js",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/hnf-emerald-titanium.html" },
    { "source": "/hnf-pro-v3.html", "destination": "/hnf-pro-v3-gpt.html" }
  ]
}
