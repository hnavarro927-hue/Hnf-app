# Entorno LOCAL (npm run dev en frontend).
# Todas las llamadas (incl. POST /auth/login) van al backend en esta máquina.
# No commitear secretos aquí; la URL pública del API local es segura de versionar.
# 127.0.0.1 evita fallos en Windows cuando "localhost" resuelve a IPv6 (::1) y el stack no coincide.
VITE_API_BASE_URL=http://127.0.0.1:4000
